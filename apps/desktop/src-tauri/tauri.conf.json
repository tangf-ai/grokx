{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grokx",
  "version": "0.1.1",
  "identifier": "app.grokx.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grokx",
        "width": 1360,
        "height": 860,
        "resizable": true,
        "backgroundColor": "#f4f4f5"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/henry.w@example.net",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/runtime/*"
    ]
  },
  "plugins": {}
}
